{
  "compilerOptions": {
    "jsx": "react-jsx",
    "strict": false,
    "noImplicitAny": false,
    "verbatimModuleSyntax": false,
    "skipLibCheck": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.app.json" }, { "path": "./tsconfig.node.json" }]
}